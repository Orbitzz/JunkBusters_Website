# Copy this file to .env and fill in your values
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=www.junkbustershauling.com,junkbustershauling.com
CSRF_TRUSTED_ORIGINS=https://www.junkbustershauling.com,https://junkbustershauling.com

# Database (leave blank for SQLite in dev; Railway/Heroku set this automatically)
DATABASE_URL=

# FieldCommand integration
FIELDCOMMAND_EMBED_URL=https://your-fieldcommand-domain.com/marketing/api/embed/{endpoint}/
FIELDCOMMAND_EMBED_API_KEY=your-fc-embed-key-here
FIELDCOMMAND_REVIEWS_URL=https://your-fieldcommand-domain.com/marketing/api/widget/reviews/

# Google review link
GOOGLE_REVIEW_URL=https://g.page/r/CaQvxFrtKJyzEBM/review

# Google Maps / Places API
GOOGLE_MAPS_API_KEY=your-key-here
GOOGLE_PLACE_ID=your-place-id-here

# Google OAuth (for live reviews)
GOOGLE_OAUTH_CLIENT_ID=your-client-id-here
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret-here
GOOGLE_OAUTH_REDIRECT_URI=https://www.junkbustershauling.com/google-auth/callback/
